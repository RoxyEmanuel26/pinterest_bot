# ============================================================
# Pinterest Bot — Environment Variables Template
# ============================================================
# Salin file ini menjadi .env lalu isi dengan nilai asli.
#   copy .env.example .env
#
# JANGAN commit file .env ke Git!

# --- Password Akun Pinterest ---
# Sesuaikan jumlah dan urutan dengan array "accounts" di config.json
ACCOUNT_1_PASSWORD=your_password_here
ACCOUNT_2_PASSWORD=your_password_here
ACCOUNT_3_PASSWORD=your_password_here

# --- Telegram Notification (opsional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Discord Notification (opsional) ---
DISCORD_WEBHOOK_URL=
